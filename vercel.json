{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm config set legacy-peer-deps true && npm config set force true && npm ci --no-audit --no-fund",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/payhero/initiate",
      "destination": "/api/payhero/initiate.js"
    },
    {
      "source": "/api/payhero/callback",
      "destination": "/api/payhero/callback.js"
    },
    {
      "source": "/api/stk-push",
      "destination": "/api/payhero/initiate.js"
    },
    {
      "source": "/api/payment-status",
      "destination": "/api/payhero/status.js"
    },
    {
      "source": "/:path(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-Requested-With, Content-Type, Authorization, Accept"
        }
      ]
    }
  ]
}
